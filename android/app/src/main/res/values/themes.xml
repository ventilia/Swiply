<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Базовая тема: реальное оформление — в Compose (SwiplyTheme) -->
    <style name="Theme.Swiply" parent="Theme.AppCompat.DayNight.NoActionBar" />

    <!-- Splash: тёмный брендовый фон + искра -->
    <style name="Theme.Swiply.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#121016</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Swiply</item>
    </style>
</resources>
